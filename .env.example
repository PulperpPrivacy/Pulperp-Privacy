# === LLM Provider ===
LLM_API_KEY=your_anthropic_or_openai_key
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL_NAME=claude-sonnet-4-6

# DeepInfra fallback
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct

# === Solana ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
HELIUS_API_KEY=
HELIUS_RPC_URL=

# === Privacy ===
# Generate with: python backend/scripts/keygen.py
VAULT_ENCRYPTION_KEY=
PRIVACY_COMMITMENT_SALT=
BLIND_QUERY_PROXY=true

# === CoinGecko ===
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# === Flask ===
FLASK_ENV=development
FLASK_PORT=5001
FLASK_DEBUG=true

# === Signal Config ===
SIGNAL_CONFIDENCE_THRESHOLD=0.65
MAX_LLM_CALLS=10
SUPPORTED_MARKETS=SOL-PERP,BTC-PERP,ETH-PERP,WIF-PERP,BONK-PERP,JUP-PERP
